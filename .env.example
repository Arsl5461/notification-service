# Database (async for FastAPI)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/notification_db
# Sync for Celery
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/notification_db

REDIS_URL=redis://localhost:6379/0

# Use a long random string in production
SECRET_KEY=change-me-in-production-use-long-random-string

# Firebase (FCM) - one of:
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json
# FIREBASE_CREDENTIALS_BASE64=<base64-encoded JSON>

# CORS (comma-separated origins for admin panel)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# pgAdmin (optional; defaults: admin@admin.com / admin)
# PGADMIN_EMAIL=admin@admin.com
# PGADMIN_PASSWORD=admin

# Flower (Celery monitoring; optional; default login: admin / admin)
# FLOWER_AUTH=username:password
